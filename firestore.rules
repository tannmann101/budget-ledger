rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in [
          'tannerwesgardner@gmail.com',
          'rochelleygardner@gmail.com'
        ];
    }

    // Guards against a client bug (or a stray manual edit) corrupting the one
    // shared document everyone reads and writes -- checks each core field's
    // *type* when required, not every nested item's shape, so the schema can
    // still evolve (new fields, renamed assumption keys) without a rules
    // deploy blocking legitimate writes.
    function isValidLedger(d) {
      return d.checking is number &&
        d.savings is number &&
        d.income is list &&
        d.debts is list &&
        d.bills is list &&
        d.categories is list &&
        d.expenses is list &&
        d.transactions is list &&
        d.history is list &&
        (!('assumptions' in d) || d.assumptions is map) &&
        (!('_rev' in d) || d._rev is number);
    }

    match /ledger/{docId} {
      allow read: if isAllowed();
      allow create, update: if isAllowed() && isValidLedger(request.resource.data);
      allow delete: if false;
    }
  }
}
